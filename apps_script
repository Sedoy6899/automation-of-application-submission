      'Разряд',
      'Город',
      'Тренеры',
      'Организация',
      'Категория'
    ];
  }
  else if (actualProgramType === 'Двойки и тройки') {
    headers = [
      '№',
      'Название команды',
      'ФИО гимнастки',
      'Год рождения',
      'Разряд',
      'Город',
      'Тренеры',
      'Организация',
      'Категория'
    ];
  }
  else if (actualProgramType === 'ОФП') {
    headers = [
      '№',
      'ФИО гимнастки',
