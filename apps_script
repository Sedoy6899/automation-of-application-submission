      'Год рождения',
      'Город',
      'Тренеры',
      'Организация',
      'Дивизион'
    ];
  } 
  else if (actualProgramType === 'Групповое упражнение') {
    headers = [
      '№',
      'Название команды',
      'ФИО гимнастки',
